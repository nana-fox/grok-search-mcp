# 官方 xAI API Key,从 https://console.x.ai 获取
XAI_API_KEY=xai-your-key-here
# 可选:模型名,默认 grok-4.3。可用模型见 https://docs.x.ai/developers/models
GROK_MODEL=grok-4.3
# 可选:第三方中转站 base URL(需兼容 xAI Responses API,如 NanaFocus)。
# 不设则用官方 https://api.x.ai/v1。设置后 XAI_API_KEY 填中转站的 key。
# XAI_BASE_URL=https://your-relay.example.com/v1
# 可选:单次请求超时(毫秒),默认 120000。慢网络/中转站可调大。
# GROK_TIMEOUT_MS=120000
